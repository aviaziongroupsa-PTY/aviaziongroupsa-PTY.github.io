---
---

<div
  x-data="{
    salario: '',
    horasDiurnas: 0,
    horasNocturnas: 0,
    horasFeriado: 0,
    resultado: null,
    get salarioHora() {
      return (parseFloat(this.salario) || 0) / 208;
    },
    calcular() {
      const s = parseFloat(this.salario) || 0;
      if (s <= 0) return;
      const sh = s / 208;
      const diurno = parseFloat(this.horasDiurnas) || 0;
      const nocturno = parseFloat(this.horasNocturnas) || 0;
      const feriado = parseFloat(this.horasFeriado) || 0;
      this.resultado = {
        salarioHora: sh,
        montoDiurno: parseFloat((sh * 1.25 * diurno).toFixed(2)),
        montoNocturno: parseFloat((sh * 1.50 * nocturno).toFixed(2)),
        montoFeriado: parseFloat((sh * 2.00 * feriado).toFixed(2)),
        total: parseFloat(((sh * 1.25 * diurno) + (sh * 1.50 * nocturno) + (sh * 2.00 * feriado)).toFixed(2)),
        horasDiurnas: diurno,
        horasNocturnas: nocturno,
        horasFeriado: feriado,
      };
    }
  }"
  class="space-y-5"
>
  <p class="text-xs text-[var(--color-muted)] bg-blue-50 border border-blue-100 rounded-lg px-4 py-2">
    Ley 44 de 1995, Art. 26 — Jornada 6×1: <strong>Base 208 h/mes</strong> (26 días × 8 h). Diurno ×1.25 | Nocturno ×1.50 | Feriado / Día de descanso ×2.00.
  </p>

  <div class="max-w-xs">
    <label class="block text-sm font-medium text-[var(--color-text)] mb-1">Salario mensual (B/.)</label>
    <input
      x-model="salario"
      type="number" min="0" placeholder="Ej: 1000"
      class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/30 focus:border-[var(--color-primary)]"
    />
    <p class="text-xs text-[var(--color-muted)] mt-1">
      Salario/hora: <strong x-text="salario ? 'B/. ' + salarioHora.toFixed(4) : '—'"></strong>
      <span class="text-[var(--color-accent)] font-medium"> (Base: 208 h — jornada 6×1)</span>
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div>
      <label class="block text-sm font-medium text-[var(--color-text)] mb-1">Horas diurnas extras</label>
      <input x-model="horasDiurnas" type="number" min="0" step="0.5" placeholder="0"
        class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/30 focus:border-[var(--color-primary)]" />
      <p class="text-xs text-[var(--color-muted)] mt-1">Factor ×1.25</p>
    </div>
    <div>
      <label class="block text-sm font-medium text-[var(--color-text)] mb-1">Horas nocturnas extras</label>
      <input x-model="horasNocturnas" type="number" min="0" step="0.5" placeholder="0"
        class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/30 focus:border-[var(--color-primary)]" />
      <p class="text-xs text-[var(--color-muted)] mt-1">Factor ×1.50</p>
    </div>
    <div>
      <label class="block text-sm font-medium text-[var(--color-text)] mb-1">Feriados / Día de descanso obligatorio</label>
      <input x-model="horasFeriado" type="number" min="0" step="0.5" placeholder="0"
        class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]/30 focus:border-[var(--color-primary)]" />
      <p class="text-xs text-[var(--color-muted)] mt-1">Factor ×2.00</p>
    </div>
  </div>

  <button
    @click="calcular()"
    class="bg-[var(--color-primary)] text-white font-semibold px-6 py-2.5 rounded-lg hover:bg-[var(--color-primary-dark)] transition-colors"
  >
    Calcular sobretiempos
  </button>

  <div x-show="resultado" x-transition class="bg-green-50 border border-green-200 rounded-xl p-5 space-y-3" style="display:none;">
    <h4 class="font-semibold text-green-800">Resumen de Sobretiempos</h4>
    <div class="text-sm text-[var(--color-muted)]">
      Salario/hora: <span class="font-mono font-semibold text-[var(--color-text)]" x-text="'B/. ' + (resultado?.salarioHora ?? 0).toFixed(4)"></span>
      <span class="text-xs text-[var(--color-accent)] font-medium ml-1">(208 h mensuales — jornada 6×1)</span>
    </div>
    <div class="space-y-1.5 text-sm">
      <template x-if="resultado?.horasDiurnas > 0">
        <div class="flex justify-between">
          <span class="text-[var(--color-muted)]">Diurnas (<span x-text="resultado.horasDiurnas"></span>h × ×1.25):</span>
          <span class="font-mono font-medium" x-text="'B/. ' + resultado.montoDiurno.toFixed(2)"></span>
        </div>
      </template>
      <template x-if="resultado?.horasNocturnas > 0">
        <div class="flex justify-between">
          <span class="text-[var(--color-muted)]">Nocturnas (<span x-text="resultado.horasNocturnas"></span>h × ×1.50):</span>
          <span class="font-mono font-medium" x-text="'B/. ' + resultado.montoNocturno.toFixed(2)"></span>
        </div>
      </template>
      <template x-if="resultado?.horasFeriado > 0">
        <div class="flex justify-between">
          <span class="text-[var(--color-muted)]">Feriado/Descanso (<span x-text="resultado.horasFeriado"></span>h × ×2.00):</span>
          <span class="font-mono font-medium" x-text="'B/. ' + resultado.montoFeriado.toFixed(2)"></span>
        </div>
      </template>
    </div>
    <div class="border-t border-green-200 pt-3 flex justify-between items-center">
      <span class="font-semibold text-green-800">Total sobretiempos:</span>
      <span class="font-mono text-2xl font-bold text-green-700" x-text="'B/. ' + (resultado?.total ?? 0).toFixed(2)"></span>
    </div>
    <p class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 leading-relaxed">
      ⚠️ <strong>Referencia orientativa.</strong> Este cálculo tiene como objetivo brindar una referencia de cómo se obtienen los montos, pero el valor real siempre estará sujeto a la realidad particular de cada empleado.
    </p>
  </div>
</div>
