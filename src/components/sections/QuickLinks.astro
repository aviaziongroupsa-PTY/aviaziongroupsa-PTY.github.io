---
import type { QuickLink } from '../../lib/types';

interface Props {
  links: QuickLink[];
}
const { links } = Astro.props;

function safeUrl(url: string): string {
  try {
    const parsed = new URL(url);
    return ['https:', 'http:'].includes(parsed.protocol) ? url : '#';
  } catch {
    return '#';
  }
}

const VALID_ICONS = new Set(['user-plus', 'clock', 'file-text', 'dollar-sign', 'briefcase', 'receipt', 'calendar', 'receipt-tax', 'help-circle', 'person-document', 'handshake']);

