---

<div class="py-16 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-semibold text-[var(--color-text)] mb-2 text-center">Accesos Rápidos</h2>
    <p class="text-[var(--color-muted)] text-center mb-10">Todos tus formularios en un solo lugar</p>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
      {links.map((link) => {
        const isProvider = link.id === 'proveedores';
        return (
          <a
            href={safeUrl(link.url)}
            target="_blank"
            rel="noopener noreferrer"
            class={`group rounded-xl p-6 flex flex-col gap-3 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 ${
              isProvider
                ? 'bg-[var(--color-primary)] border border-[var(--color-primary-2)]'
                : 'bg-[var(--color-surface)] border border-[var(--color-border)]'
            }`}
          >
            <div class={`w-10 h-10 ${isProvider ? 'text-[var(--color-accent)]' : 'text-[var(--color-primary)]'}`}
              set:html={icons[VALID_ICONS.has(link.icon) ? link.icon : 'file-text']} />
            <div>
              <span class={`inline-block text-xs font-medium px-2 py-0.5 rounded-full mb-2 ${
                isProvider
                  ? 'bg-white/15 text-white'
                  : 'bg-[var(--color-accent)]/15 text-[var(--color-primary-dark)]'
              }`}>
                {link.category}
              </span>
              <h3 class={`font-semibold transition-colors ${
                isProvider
                  ? 'text-white group-hover:text-[var(--color-accent)]'
                  : 'text-[var(--color-text)] group-hover:text-[var(--color-primary)]'
              }`}>
                {link.title}
              </h3>
              <p class={`text-sm mt-1 ${isProvider ? 'text-white/60' : 'text-[var(--color-muted)]'}`}>
                {link.description}
              </p>
            </div>
            <div class={`mt-auto flex items-center text-sm font-medium ${isProvider ? 'text-[var(--color-accent)]' : 'text-[var(--color-primary)]'}`}>
              Abrir formulario
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</div>
