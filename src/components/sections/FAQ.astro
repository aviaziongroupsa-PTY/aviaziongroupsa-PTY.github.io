---
import type { FAQItem } from '../../lib/types';

interface Props {
  items: FAQItem[];
}
const { items } = Astro.props;

const safeId = (id: number) => parseInt(String(id), 10) || 0;
---

<section id="faq" class="py-24 px-4 md:px-8" style="background-color: var(--color-bg);">
  <div class="max-w-3xl mx-auto">
    <div class="mb-12 text-center">
      <span class="eyebrow">Soporte</span>
      <h2 class="text-4xl font-bold text-[var(--color-text)] mb-3">Preguntas frecuentes</h2>
      <p class="text-[var(--color-muted)] max-w-[44ch] mx-auto">Respuestas a las dudas más comunes sobre tus derechos laborales.</p>
    </div>

    <div x-data="{ open: null }" class="divide-y" style="border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
      {items.map((item, index) => {
        const num = String(index + 1).padStart(2, '0');
        return (
          <div class="transition-colors duration-200" x-bind:class={`open === ${safeId(item.id)} ? 'bg-[rgba(27,122,200,0.05)]' : ''`} style="border-color: var(--color-border);">
            <button
              x-on:click={`open = open === ${safeId(item.id)} ? null : ${safeId(item.id)}`}
              class="w-full flex items-center gap-4 px-4 py-5 text-left transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-[var(--color-primary-2)]"
            >
              <!-- Number -->
              <span class="flex-shrink-0 text-xs font-mono font-semibold w-6 text-right" style="color: var(--color-primary-2);">{num}</span>
              <!-- Question -->
              <span class="flex-1 font-medium text-[var(--color-text)] group-hover:text-white">{item.question}</span>
              <!-- Icon -->
              <svg
                x-bind:class={`open === ${safeId(item.id)} ? 'rotate-45' : ''`}
                class="w-4 h-4 flex-shrink-0 transition-transform duration-200 text-[var(--color-muted)]"
                fill="none" stroke="currentColor" viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </button>
            <div
              x-show={`open === ${safeId(item.id)}`}
              x-transition:enter="transition ease-out duration-200"
              x-transition:enter-start="opacity-0 -translate-y-1"
              x-transition:enter-end="opacity-100 translate-y-0"
              x-transition:leave="transition ease-in duration-150"
              x-transition:leave-start="opacity-100 translate-y-0"
              x-transition:leave-end="opacity-0 -translate-y-1"
              class="pl-14 pr-4 pb-5"
              style="display: none;"
            >
              <p class="text-[var(--color-muted)] leading-relaxed max-w-[60ch]">{item.answer}</p>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
