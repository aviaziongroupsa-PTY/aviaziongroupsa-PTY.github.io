---
import OvertimeCalc from '../calculators/OvertimeCalc.astro';
import VacationCalc from '../calculators/VacationCalc.astro';
import ThirteenthCalc from '../calculators/ThirteenthCalc.astro';
import LiquidationCalc from '../calculators/LiquidationCalc.astro';

const tabs = [
  { id: 'sobretiempo', label: 'Sobretiempos' },
  { id: 'vacaciones', label: 'Vacaciones' },
  { id: 'decimo', label: 'Décimo Tercer Mes' },
  { id: 'liquidacion', label: 'Liquidación' },
];
---

<div class="py-16 px-4 md:px-8 bg-[var(--color-bg)]">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-semibold text-[var(--color-text)] mb-2 text-center">Calculadoras Laborales</h2>
    <p class="text-[var(--color-muted)] text-center mb-10">Cálculos basados en la legislación laboral vigente de Panamá — jornada 6×1 / 208 h mensuales</p>

    <div
      x-data="{ tab: 'sobretiempo' }"
      class="rounded-2xl overflow-hidden"
      style="background: rgba(13,27,46,0.7); border: 1px solid var(--color-border); backdrop-filter: blur(12px);"
    >
      <!-- Tabs -->
      <div class="flex overflow-x-auto" style="border-bottom: 1px solid var(--color-border);">
        {tabs.map((t) => (
          <button
            x-on:click={`tab = '${t.id}'`}
            x-bind:class={`tab === '${t.id}' ? 'border-b-2 border-[var(--color-primary-2)] text-white font-semibold bg-[rgba(27,122,200,0.10)]' : 'text-[var(--color-muted)] hover:text-[var(--color-text)]'`}
            class="px-5 py-4 text-sm whitespace-nowrap transition-all duration-200 flex-shrink-0"
          >
            {t.label}
          </button>
        ))}
      </div>

      <!-- Panels -->
      <div class="p-6 md:p-8">
        <div x-show="tab === 'sobretiempo'"><OvertimeCalc /></div>
        <div x-show="tab === 'vacaciones'" style="display:none;"><VacationCalc /></div>
        <div x-show="tab === 'decimo'" style="display:none;"><ThirteenthCalc /></div>
        <div x-show="tab === 'liquidacion'" style="display:none;"><LiquidationCalc /></div>
      </div>
    </div>
  </div>
</div>
