---
interface Props {
  site: {
    name: string;
    tagline: string;
    logoUrl: string;
  };
}
const { site } = Astro.props;
---

<section id="inicio" class="relative text-white overflow-hidden" style="background-color: var(--color-primary);">
  <!-- Grain overlay -->
  <div class="grain-overlay" aria-hidden="true"></div>
  <!-- Radial glow top-right in primary-2 -->
  <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(27,122,200,0.22) 0%, transparent 70%);" aria-hidden="true"></div>
  <!-- Subtle accent glow bottom-left -->
  <div class="absolute -bottom-24 -left-24 w-80 h-80 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(232,140,14,0.10) 0%, transparent 70%);" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 md:px-8 py-20 md:py-28">
    <div class="flex flex-col md:flex-row md:items-center gap-10 md:gap-16">
      <!-- Logo -->
      <div class="flex-shrink-0 flex justify-center md:justify-start">
        <div class="bg-white rounded-xl px-8 py-5 shadow-[0_4px_24px_rgba(0,0,0,0.20)] border border-white/20">
          <img
            src={site.logoUrl}
            alt="Aviazion Group"
            class="h-16 md:h-24 w-auto"
          />
        </div>
      </div>
      <!-- Text -->
      <div class="text-center md:text-left">
        <p class="text-[var(--color-accent)] text-sm font-semibold tracking-widest uppercase mb-3">Portal de Recursos Humanos</p>
        <h1 class="text-4xl md:text-5xl font-bold leading-[1.1] mb-4">{site.name}</h1>
        <p class="text-white/65 text-lg md:text-xl mb-8 max-w-[52ch]">{site.tagline}</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start">
          <a
            href="#accesos"
            class="inline-block bg-[var(--color-accent)] text-white font-semibold px-8 py-3 rounded-lg hover:brightness-105 hover:-translate-y-0.5 active:scale-[0.98] active:translate-y-0 transition-all duration-200"
          >
            Ver accesos rápidos
          </a>
          <a
            href="#calculadoras"
            class="inline-block bg-white/10 text-white border border-white/20 font-semibold px-8 py-3 rounded-lg hover:bg-white/20 hover:-translate-y-0.5 active:scale-[0.98] active:translate-y-0 transition-all duration-200"
          >
            Ir a calculadoras
          </a>
        </div>
      </div>
    </div>
  </div>
  <!-- Bottom accent line -->
  <div class="absolute bottom-0 left-0 right-0 h-[2px]" style="background: linear-gradient(90deg, transparent, var(--color-primary-2), var(--color-accent), var(--color-primary-2), transparent);" aria-hidden="true"></div>
</section>
