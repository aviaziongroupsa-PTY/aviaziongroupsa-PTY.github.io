---
interface Props {
  site: {
    name: string;
    tagline: string;
    logoUrl: string;
  };
}
const { site } = Astro.props;
---

<section class="relative text-white py-20 md:py-28 overflow-hidden" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-2) 100%);">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full opacity-10" style="background: var(--color-primary-2);"></div>
    <div class="absolute -bottom-16 -left-16 w-64 h-64 rounded-full opacity-10" style="background: var(--color-primary-2);"></div>
  </div>
  <div class="relative max-w-6xl mx-auto px-4 md:px-8 text-center">
    <div class="flex justify-center mb-8">
      <div class="bg-white rounded-2xl px-10 py-6 shadow-xl">
        <img
          src={site.logoUrl}
          alt="Aviazion Group"
          class="h-20 md:h-28 w-auto"
        />
      </div>
    </div>
    <h1 class="text-3xl md:text-5xl font-bold mb-4 leading-tight">
      {site.name}
    </h1>
    <p class="text-white/70 text-lg md:text-xl mb-10 max-w-2xl mx-auto">
      {site.tagline}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#accesos"
        class="bg-[var(--color-accent)] hover:opacity-90 text-white font-semibold px-8 py-3 rounded-lg transition-opacity duration-200"
      >
        Ver Accesos Rápidos
      </a>
      <a
        href="#calculadoras"
        class="bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-3 rounded-lg border border-white/20 transition-colors duration-200"
      >
        Ir a Calculadoras
      </a>
    </div>
  </div>
  <div class="absolute bottom-0 left-0 right-0 h-1" style="background: linear-gradient(90deg, var(--color-primary-2), var(--color-accent), var(--color-primary-2));"></div>
</section>
