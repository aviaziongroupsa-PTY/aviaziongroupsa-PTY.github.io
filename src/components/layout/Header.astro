---
interface Props {
  logo: string;
}
const { logo } = Astro.props;
---

<header
  x-data="{ scrolled: false }"
  x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 60 })"
  x-bind:class="scrolled ? 'bg-[rgba(7,15,28,0.90)] border-b border-[var(--color-border)] shadow-lg' : 'bg-transparent border-b border-transparent'"
  class="fixed top-0 left-0 right-0 z-50 h-16 transition-all duration-300"
  style="backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);"
>
  <div class="max-w-6xl mx-auto px-4 md:px-8 h-full flex items-center justify-between">
    <a href="#inicio" class="flex items-center gap-3">
      <div class="bg-white/10 border border-white/15 rounded-lg px-2 py-1 flex items-center">
        <img src={logo} alt="Aviazion Group" class="h-7 w-auto" />
      </div>
      <span class="text-white font-semibold text-sm leading-tight hidden sm:block">
        Portal RRHH<br />
        <span class="text-[var(--color-primary-2)] text-xs font-normal">Aviazion Group</span>
      </span>
    </a>
    <nav class="hidden md:flex items-center gap-6">
      <a href="#accesos" class="text-white/60 hover:text-white text-sm font-medium transition-colors duration-200">Accesos Rápidos</a>
      <a href="#calculadoras" class="text-white/60 hover:text-white text-sm font-medium transition-colors duration-200">Calculadoras</a>
      <a href="#faq" class="text-white/60 hover:text-white text-sm font-medium transition-colors duration-200">FAQ</a>
    </nav>
    <button
      x-data="{ open: false }"
      @click="open = !open"
      class="md:hidden text-white/70 hover:text-white p-2 transition-colors"
      aria-label="Menú"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</header>
