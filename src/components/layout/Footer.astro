---
interface Props {
  email: string;
}
const { email } = Astro.props;
---

<footer style="background-color: var(--color-primary-dark); border-top: 1px solid var(--color-border);">
  <div class="max-w-6xl mx-auto px-4 md:px-8">
    <div class="py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs font-mono tracking-widest uppercase" style="color: var(--color-muted);">
        © {new Date().getFullYear()} Aviazion Group — Todos los derechos reservados
      </p>
      <a
        href={`mailto:${email}`}
        class="text-xs font-mono transition-colors duration-200"
        style="color: var(--color-primary-2);"
        onmouseover="this.style.color='white'"
        onmouseout="this.style.color='var(--color-primary-2)'"
      >{email}</a>
    </div>
  </div>
</footer>
